  "maqamDetectionRules": {
    "rast": {
      "primaryRules": [
        {
          "ruleId": "rule-rast-001",
          "description": "وجود النغمة سيكاه (350 سنت) في بداية الجملة",
          "condition": "pitch_at_position_0_2 BETWEEN 345 AND 355",
          "weight": 0.8
        },
        {
          "ruleId": "rule-rast-002",
          "description": "عودة متكررة لنغمة اليكاه (C)",
          "condition": "tonic_frequency > 0.7",
          "weight": 0.9
        },
        {
          "ruleId": "rule-rast-003",
          "description": "نمط صعودي: C -> D -> Eb/2 -> F",
          "condition": "pitch_sequence IN [0,200,350,500]",
          "weight": 0.85
        },
        {
          "ruleId": "rule-rast-004",
          "description": "تحول إلى نهاوند على درجة النوى (G)",
          "condition": "modulation_detected TO nahawand AT degree_5",
          "weight": 0.6
        },
        {
          "ruleId": "rule-rast-005",
          "description": "وجود ربع تون على الدرجة الثالثة (E نصف بيمول)",
          "condition": "microtone_at_degree_3 = -50_cents",
          "weight": 0.95
        }
      ],
      "secondaryRules": [
        {
          "ruleId": "rule-rast-006",
          "description": "استقرار على الدوكاه (D) كمركز ثانوي",
          "condition": "secondary_tonic = D frequency > 0.5",
          "weight": 0.5
        }
      ],
      "modulationPatterns": [
        {
          "to": "nahawand",
          "pattern": "G -> A -> Bb -> C (على درجة النوى)",
          "triggerNote": "G",
          "confidence": 0.8
        },
        {
          "to": "hijaz",
          "pattern": "D -> Eb/2 -> F# -> G (على درجة الدوكاه)",
          "triggerNote": "D",
          "confidence": 0.7
        },
        {
          "to": "bayat",
          "pattern": "C -> D -> Eb/2 -> F (تغيير طفيف في السيكاه)",
          "triggerNote": "C",
          "confidence": 0.5
        }
      ],
      "exceptionRules": [
        {
          "description": "إذا كان هناك استخدام مكثف للدرجات العليا > 1200 سنت، قد يكون رست النوى",
          "condition": "upper_register_usage > 0.6",
          "exception": "rast_al_nawa"
        }
      ],
      "machineLearningFeatures": {
        "primary": ["chroma_vector[0,2,3,5]", "mfcc_mean[1-4]", "pitch_class_distribution"],
        "secondary": ["spectral_centroid", "zero_crossing_rate", "rolloff"]
      }
    },
    
    "bayat": {
      "primaryRules": [
        {
          "ruleId": "rule-bayat-001",
          "description": "وجود ربعي تون على الدرجتين الثانية (50 سنت) والثالثة (350 سنت)",
          "condition": "microtone_at_degree_2 = +50_cents AND microtone_at_degree_3 = -50_cents",
          "weight": 0.95
        },
        {
          "ruleId": "rule-bayat-002",
          "description": "نمط لحني: D -> Eb/4 -> D -> C",
          "condition": "phrase_pattern = [200,250,200,0]",
          "weight": 0.85
        },
        {
          "ruleId": "rule-bayat-003",
          "description": "حزن وشجن في الأداء",
          "condition": "emotional_profile_match = sadness > 0.7",
          "weight": 0.6
        }
      ]
    },
    
    "hijaz": {
      "primaryRules": [
        {
          "ruleId": "rule-hijaz-001",
          "description": "البعد المتزايد (150 سنت) بين الدرجة الأولى والثانية",
          "condition": "interval_1_2 BETWEEN 145 AND 155",
          "weight": 0.9
        },
        {
          "ruleId": "rule-hijaz-002",
          "description": "وجود ربع تون على الدرجة الرابعة (F#)",
          "condition": "note_at_degree_4 = F#_quarter_sharp",
          "weight": 0.85
        }
      ]
    }
  },

